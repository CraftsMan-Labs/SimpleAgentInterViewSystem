# -------------------------------
# Local workflow runtime settings
# -------------------------------
WORKFLOW_PROVIDER=openai
WORKFLOW_API_BASE=
WORKFLOW_API_KEY=
WORKFLOW_MODEL=
WORKFLOW_PATH=workflows/python-intern-fun-interview-chat.yaml

# -----------------------------------------
# Optional SimpleFlow control-plane settings
# -----------------------------------------
SIMPLEFLOW_API_BASE_URL=
SIMPLEFLOW_API_TOKEN=
SIMPLEFLOW_CLIENT_ID=
SIMPLEFLOW_CLIENT_SECRET=

# -----------------------------------------
# Optional fallback agent bootstrap settings
# (used when SIMPLEFLOW_AGENT_CATALOG_JSON is not provided)
# -----------------------------------------
# Must be the control-plane Agent ID UUID (not agent name).
RUNTIME_AGENT_ID=
RUNTIME_AGENT_VERSION=v1
RUNTIME_ORG_ID=
RUNTIME_BOOTSTRAP_ENDPOINT_URL=
RUNTIME_BOOTSTRAP_RUNTIME_ID=
# Optional explicit public base URL used for auto-generated runtime endpoint URL
# when runtime_endpoint_url is not provided in agent catalog entries.
RUNTIME_PUBLIC_BASE_URL=

# -----------------------------------------
# Agent catalog used by onboarding + selector UI
# -----------------------------------------
# SIMPLEFLOW_AGENT_CATALOG_JSON=[{"agent_id":"7488518a-0a6f-4fdc-a34c-ac10a78db216","agent_version":"v1","org_id":"12a41399-feac-4d04-8f0c-05dfa8a2c2a6","runtime_endpoint_url":"https://your-runtime.example.com","runtime_id":"hr-runtime-1","enabled":true}]
